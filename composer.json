{
    "name": "mojahed/multiquery",
    "description": "Parallel MySQL query execution for Laravel projects - Run multiple MySQL queries in parallel for efficient execution.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Md Mojahedul Islam",
            "email": "dev.mojahedul@gmail.com",
            "homepage": "https://md-mojahed.github.io"
        }
    ],
    "keywords": ["mysql", "parallel", "multiquery", "laravel", "performance", "concurrent", "database"],
    "require": {
        "php": "^8.1",
        "illuminate/database": "^10.0|^11.0|^12.0",
        "illuminate/support": "^10.0|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Mojahed\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mojahed\\MultiQueryServiceProvider"
            ],
            "aliases": {
                "MultiQuery": "Mojahed\\Facades\\MultiQuery"
            }
        }
    },
    "minimum-stability": "stable"
}
